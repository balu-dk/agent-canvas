{
  "session_start": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".openhands/setup.sh",
          "timeout": 300
        }
      ]
    }
  ],
  "stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".openhands/hooks/on_stop.sh",
          "timeout": 600
        }
      ]
    }
  ]
}
